<!DOCTYPE html>
<html>
<head>
<title>Avatar Feature Task</title>
<script>
  setTimeout(function() {
    // 3 मिनट बाद यहाँ एडस्टेरा का कोड ट्रिगर होगा
    alert("3 मिनट का फ्री सेशन समाप्त. टास्क पूरा करें 10 मिनट के लिए.");
  }, 180000); // 3 मिनट = 180,000 मिलीसेकंड्स

  function grantAccess() {
    // टास्क पूरा होने पर, टाइमर 10 मिनट के लिए बढ़ाएँ
    alert("टास्क पूरा हुआ! अब आपको 10 मिनट का एक्सेस मिला है.");
  }
</script>
</head>
<body>
  <h1>आपका अवतार फीचर यहाँ है</h1>
  <p>यहाँ आप 3 मिनट तक फ्री चैट कर सकते हैं.</p>
  <!-- एडस्टेरा या अन्य विज्ञापन कोड यहाँ डालें -->
  <button onclick="grantAccess()">टास्क पूरा किया (पैसे/समय पाएँ)</button>
</body>
</html>
