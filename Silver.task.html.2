<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Silver Task</title>
  <style>
    :root {
      --bg: #0f1b16;
      --card: #16271f;
      --green: #22c55e;
      --green-soft: #4ade80;
      --text: #e8f5ee;
      --muted: #9fb3a8;
      --border: #1f3a2c;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      background: radial-gradient(1200px 600px at 50% -10%, #16332a, var(--bg));
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .card {
      width: 100%;
      max-width: 460px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 32px;
      text-align: center;
      box-shadow: 0 20px 60px rgba(0,0,0,.45);
    }
    .badge {
      display: inline-block;
      padding: 6px 14px;
      background: rgba(34,197,94,.12);
      color: var(--green-soft);
      border: 1px solid rgba(34,197,94,.3);
      border-radius: 999px;
      font-size: 13px;
      font-weight: 600;
      margin-bottom: 20px;
    }
    h1 { font-size: 22px; margin-bottom: 8px; }
    .sub { color: var(--muted); font-size: 14px; margin-bottom: 28px; line-height: 1.5; }
    .amount {
      font-size: 56px;
      font-weight: 800;
      color: var(--green);
      letter-spacing: -1px;
      line-height: 1.1;
      text-shadow: 0 0 30px rgba(34,197,94,.35);
    }
    .amount .currency { font-size: 28px; vertical-align: super; margin-right: 4px; opacity: .8; }
    .progress {
      margin: 24px 0 8px;
      height: 8px;
      background: #0c1812;
      border-radius: 999px;
      overflow: hidden;
    }
    .bar {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, var(--green), var(--green-soft));
      border-radius: 999px;
      transition: width .2s linear;
    }
    .status { color: var(--muted); font-size: 13px; min-height: 18px; margin-bottom: 20px; }
    .btn {
      width: 100%;
      padding: 14px;
      border: none;
      border-radius: 12px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: transform .12s ease, opacity .2s ease;
    }
    .btn:active { transform: scale(.98); }
    .btn-primary { background: var(--green); color: #06210f; }
    .btn-primary:hover { background: var(--green-soft); }
    .btn:disabled { opacity: .5; cursor: not-allowed; }
    .note {
      margin-top: 18px;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.5;
    }
    .pulse { animation: pulse 1.4s ease-in-out infinite; }
    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.04); }
    }
  </style>
</head>
<body>
  <main class="card" role="main">
    <span class="badge">Silver Task</span>
    <h1>रिवॉर्ड टास्क</h1>
    <p class="sub">नीचे बटन दबाकर टास्क शुरू करें। टाइमर पूरा होने पर रिवॉर्ड अपने आप जुड़ जाएगा।</p>

    <div class="amount" id="amount" aria-live="polite">
      <span class="currency">₹</span><span id="count">0.00</span>
    </div>

    <div class="progress" aria-hidden="true">
      <div class="bar" id="bar"></div>
    </div>
    <div class="status" id="status">तैयार है — शुरू करने के लिए बटन दबाएँ</div>

    <button class="btn btn-primary" id="startBtn">टास्क शुरू करें</button>

    <p class="note">
      यह टास्क विज्ञापन-नेटवर्क के नियमों के अनुसार काम करता है — कोई ज़बरदस्ती रीडायरेक्ट या छिपा हुआ विज्ञापन नहीं।
    </p>
  </main>

  <script>
    (function () {
      const startBtn = document.getElementById("startBtn");
      const countEl = document.getElementById("count");
      const barEl = document.getElementById("bar");
      const statusEl = document.getElementById("status");
      const amountEl = document.getElementById("amount");

      const DURATION = 45;
      const REWARD = 5.00;
      const TICK = 100;

      let running = false;
      let intervalId = null;

      function format(n) {
        return n.toFixed(2);
      }

      function startTask() {
        if (running) return;
        running = true;
        startBtn.disabled = true;
        startBtn.textContent = "टास्क चल रहा है...";
        amountEl.classList.add("pulse");
        statusEl.textContent = "टास्क चल रहा है — कृपया इस पेज पर बने रहें";

        const startTime = Date.now();

        intervalId = setInterval(function () {
          const elapsed = (Date.now() - startTime) / 1000;
          const progress = Math.min(elapsed / DURATION, 1);
          const current = REWARD * progress;

          countEl.textContent = format(current);
          barEl.style.width = (progress * 100) + "%";

          if (progress >= 1) {
            clearInterval(intervalId);
            intervalId = null;
            running = false;
            countEl.textContent = format(REWARD);
            barEl.style.width = "100%";
            statusEl.textContent = "टास्क पूरा! रिवॉर्ड जुड़ गया।";
            amountEl.classList.remove("pulse");
            startBtn.textContent = "फिर से करें";
            startBtn.disabled = false;
          }
        }, TICK);
      }

      startBtn.addEventListener("click", startTask);
    })();
  </script>
</body>
  </html>
  
