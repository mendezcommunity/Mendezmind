rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── wallets ──────────────────────────────────────────────────────────────
    // Anyone can read their own wallet (by userId doc key).
    // NO client writes — all writes go through Cloud Functions only.
    match /wallets/{userId} {
      allow read:  if true;   // front-end reads balance by userId
      allow write: if false;  // Cloud Functions only
    }

    // ── withdrawalRequests ───────────────────────────────────────────────────
    // Users can read their own withdrawal requests (filtered by userId field).
    // NO client writes — requestWithdrawal Cloud Function handles all writes.
    match /withdrawalRequests/{docId} {
      allow read:  if true;   // client reads own history via withdrawalHistory endpoint
      allow write: if false;  // Cloud Functions only
    }

    // ── processedTx (idempotency ledger) ────────────────────────────────────
    // Server-only — no client access.
    match /processedTx/{txId} {
      allow read:  if false;
      allow write: if false;
    }

    // ── all other collections ────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
