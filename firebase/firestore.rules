rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── wallets ──────────────────────────────────────────────────────────────
    // Anyone can read their own wallet (by userId doc key).
    // NO client writes — all writes go through Cloud Functions only.
    match /wallets/{userId} {
      allow read:  if true;   // front-end reads balance by userId
      allow write: if false;  // Cloud Functions only
    }

    // ── withdrawalRequests ───────────────────────────────────────────────────
    // Users can read their own withdrawal requests (filtered by userId field).
    // NO client writes — requestWithdrawal Cloud Function handles all writes.
    match /withdrawalRequests/{docId} {
      allow read:  if true;   // client reads own history via withdrawalHistory endpoint
      allow write: if false;  // Cloud Functions only
    }

    // ── processedTx (idempotency ledger) ─────────────────────────────────────
    // Server-only — no client access.
    match /processedTx/{txId} {
      allow read:  if false;
      allow write: if false;
    }

    // ── adminSessions (server-side auth sessions) ─────────────────────────────
    // Only authenticated Firebase users can read their own session.
    // All writes are via Cloud Functions (adminAuth endpoint).
    // Extra safety: client reads require Firebase Auth (request.auth != null).
    match /adminSessions/{sessionId} {
      allow read:  if request.auth != null;  // requires Firebase Auth token
      allow write: if false;                 // Cloud Functions only
    }

    // ── adminRateLimit (brute-force protection) ───────────────────────────────
    // Server-only — no client access.
    match /adminRateLimit/{ipKey} {
      allow read:  if false;
      allow write: if false;
    }

    // ── _health (health check ping) ───────────────────────────────────────────
    // Read-only for health endpoint — no client writes.
    match /_health/{docId} {
      allow read:  if false;
      allow write: if false;
    }

    // ── all other collections ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
