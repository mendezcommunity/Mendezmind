rules_version = '2';

// =============================================================================
// Mendez Verified Reward Wallet — Firestore Security Rules
//
// KEY PRINCIPLE: The public web client can READ a wallet balance but can NEVER
// write to it. All crediting happens ONLY inside the Cloud Function (postback),
// which uses the Admin SDK and bypasses these rules. This is what makes the
// balance "verified" — the browser cannot fake or inflate it.
// =============================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Wallet balances: readable by anyone (so the front-end can display the
    // real verified balance), but NOT writable by any client. Writes are done
    // exclusively by the Cloud Function via the Admin SDK.
    match /wallets/{userId} {
      allow read: if true;
      allow write: if false;   // clients can never credit themselves
    }

    // Processed postback transactions (idempotency ledger): fully server-only.
    // Never readable or writable from the client.
    match /postback_tx/{txId} {
      allow read, write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
